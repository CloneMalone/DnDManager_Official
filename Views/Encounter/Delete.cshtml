@model DnDManager.Models.Encounter

@{
    ViewData["Title"] = "Delete Encounter";
}

<h2>Delete Encounter</h2>

<h4>Are you sure you want to delete this?</h4>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            Name
        </dt>
        <dd class="col-sm-10">
            @Model.Name
        </dd>

        <dt class="col-sm-2">
            Outcome
        </dt>
        <dd class="col-sm-10">
            @Model.Outcome
        </dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />

        <button type="submit" class="btn btn-danger">Delete</button> |
        <a asp-action="Index">Back to List</a>
    </form>
</div>
