@model DnDManager.Models.Character

@{
    ViewData["Title"] = "Create Character";
}

<h1>Create Character</h1>

Create <form>
    <div class="form-group">
        <label asp-for="Name"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Class"></label>
        <input asp-for="Class" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="Race"></label>
        <input asp-for="Race" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="Level"></label>
        <input asp-for="Level" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="CurrentHp"></label>
        <input asp-for="CurrentHp" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="MaxHp"></label>
        <input asp-for="MaxHp" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="ArmorClass"></label>
        <input asp-for="ArmorClass" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="InitiativeBonus"></label>
        <input asp-for="InitiativeBonus" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="Status"></label>
        <input asp-for="Status" class="form-control" />
    </div>

    <br />

    <button type="submit" class="btn btn-primary">Create</button>
    <a>IndexCancel</a>
</form>
