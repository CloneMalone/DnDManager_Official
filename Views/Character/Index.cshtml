@model IEnumerable<DnDManager.Models.Character>

@{
    ViewData["Title"] = "Characters";
}

<h1>Characters</h1>

<p>
    <a>CreateCreate New Character</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Class</th>
            <th>Race</th>
            <th>Level</th>
            <th>HP</th>
            <th>AC</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
            <td>@item.Name</td>
            <td>@item.Class</td>
            <td>@item.Race</td>
            <td>@item.Level</td>
            <td>@item.CurrentHp / @item.MaxHp</td>
            <td>@item.ArmorClass</td>
            <td>
               <a> Details</a> |
              <a> Edit</a>
            </td>
        </tr>
}
    </tbody>
</table>
