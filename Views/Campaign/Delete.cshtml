@model DnDManager.Models.Campaign

@{
    ViewData["Title"] = "Delete Campaign";
}

<h1>Delete Campaign</h1>

<h3>Are you sure you want to delete this campaign?</h3>

<div class="card">
    <div class="card-body">
        <h4>@Model.Name</h4>

        <p>
            <strong>Description:</strong><br />
            @Model.Description
        </p>

        <p>
            <strong>Dungeon Master:</strong><br />
            @Model.DmName
        </p>
    </div>
</div>

<br />

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="CampaignId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
