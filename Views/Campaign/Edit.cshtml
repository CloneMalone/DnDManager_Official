@model DnDManager.Models.Campaign

@{
    ViewData["Title"] = "Edit Campaign";
}

<h1>Edit Campaign</h1>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="CampaignId" />

    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="DmName" class="form-label"></label>
        <input asp-for="DmName" class="form-control" />
        <span asp-validation-for="DmName" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
