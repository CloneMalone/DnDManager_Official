@model IEnumerable<DnDManager.Models.Campaign>

@{
    ViewData["Title"] = "Campaigns";
}

<h1>Campaigns</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Campaign</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Description</th>
            <th>Dungeon Master</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var campaign in Model)
        {
            <tr>
                <td>@campaign.Name</td>
                <td>@campaign.Description</td>
                <td>@campaign.DmName</td>
                <td>
                    <a asp-action="Details" asp-route-id="@campaign.CampaignId">Details</a> |
                    <a asp-action="Edit" asp-route-id="@campaign.CampaignId">Edit</a> |
                    <a asp-action="Delete" asp-route-id="@campaign.CampaignId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
